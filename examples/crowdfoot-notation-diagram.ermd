```ermd-table
physicalName: Book
id: tbl_mpsaezq4_cjqfa
logicalName: Book
comment: Central entity — a book title identified by ISBN
designNote: Core entity — all other tables revolve around it
columns:
  - physicalName: ISBN
    id: col_mpsaezq4_9urnf
    logicalName: ISBN
    dictionaryId: dict_mpsaezq4_gdera
    isPrimaryKey: true
    isNullable: false
    defaultValue: null
    comment: International Standard Book Number (PK)
    designNote: ISBN is the natural key for books in this domain
  - physicalName: PublisherName
    id: col_mpsaezq4_svfvc
    logicalName: Publisher Name
    dictionaryId: dict_mpsaezq4_gdera
    isPrimaryKey: false
    isNullable: true
    defaultValue: null
    comment: FK to Publisher.Name — denormalised by design
    designNote: Consider normalising to publisher_id in a future migration
  - physicalName: AuthorName
    id: col_mpsaezq4_4nxdl
    logicalName: Author Name
    dictionaryId: dict_mpsaezq4_gdera
    isPrimaryKey: false
    isNullable: true
    defaultValue: null
