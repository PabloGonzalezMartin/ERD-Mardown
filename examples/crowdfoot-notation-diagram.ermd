  fromTableId: tbl_mpsaezq4_cjqfa
  fromColumnId: col_mpsaezq4_9urnf
  toTableId: tbl_mpsaezq4_14qd3
  toColumnId: col_mpsaezq4_m7gxi
  fromCardinality: EXACTLY_ONE
  toCardinality: ZERO_OR_MANY
