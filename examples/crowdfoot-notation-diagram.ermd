## Relations

```ermd-relations
- constraintName: fk_book_author_name
  id: rel_mpsaezq4_64hd4
  fromTableId: tbl_mpsaezq4_4mvq2
  fromColumnId: col_mpsaezq4_frk88
  toTableId: tbl_mpsaezq4_cjqfa
  toColumnId: col_mpsaezq4_4nxdl
  fromCardinality: EXACTLY_ONE
  toCardinality: ZERO_OR_MANY
  identifying: false
  hasForeignKey: true
  comment: 'Non-identifying: an author can exist without having published any books yet'
- constraintName: fk_book_publisher_name
  id: rel_mpsaezq4_1gzse
  fromTableId: tbl_mpsaezq4_6ym3e
  fromColumnId: col_mpsaezq4_okodj
  toTableId: tbl_mpsaezq4_cjqfa
  toColumnId: col_mpsaezq4_svfvc
  fromCardinality: EXACTLY_ONE
  toCardinality: ZERO_OR_MANY
  identifying: false
  hasForeignKey: true
  comment: 'Non-identifying: a publisher can be registered before any books are catalogued'
- constraintName: fk_book_genre_id
  id: rel_mpsaezq4_1ghey
  fromTableId: tbl_mpsaezq4_n3qhx
  fromColumnId: col_mpsaezq4_5mf2s
